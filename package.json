{
  "name": "is2u",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @is2u/web dev",
    "build": "pnpm --filter @is2u/web build && pnpm --filter @is2u/worker build && pnpm --filter @is2u/media-worker build",
    "start": "pnpm --filter @is2u/web start",
    "worker": "pnpm --filter @is2u/worker start",
    "typecheck": "tsc --noEmit && pnpm --filter @is2u/media-worker typecheck",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx packages/db/src/migrate.ts",
    "db:seed": "tsx packages/db/src/seed.ts",
    "backup:now": "tsx scripts/backup-now.ts",
    "pin:hash": "tsx scripts/hash-pin.ts",
    "cleanup:future-missions": "tsx scripts/cleanup-future-missions.ts",
    "account:migration-report": "tsx scripts/account-migration-report.ts",
    "admin:provision": "tsx scripts/provision-admin.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1086.0",
    "@aws-sdk/s3-request-presigner": "3.1086.0",
    "argon2": "0.44.0",
    "drizzle-orm": "0.45.2",
    "html-to-image": "1.11.13",
    "luxon": "3.7.2",
    "next": "16.2.10",
    "pg-boss": "12.26.0",
    "postgres": "3.4.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sharp": "0.35.3",
    "web-push": "3.6.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "5.20260714.1",
    "@types/luxon": "3.7.2",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/web-push": "3.6.4",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10",
    "wrangler": "4.110.0"
  }
}
